# Copy to .env and fill in your values

# For OpenAI:
MODEL_PROXY_URL=https://api.openai.com/v1
MODEL_PROXY_API_KEY=sk-...
MODEL_PROXY_GENAI_SUPPORT=FALSE
LLM_DEFAULT=gpt-4o

# For OpenRouter (many models via one API):
# MODEL_PROXY_URL=https://openrouter.ai/api/v1
# MODEL_PROXY_API_KEY=sk-or-...
# LLM_DEFAULT=openai/gpt-4o

# For Gemini (with genai api, supports tools best):
# Set MODEL_PROXY_GENAI_SUPPORT=TRUE when your proxy supports Gemini's genai API.
# MODEL_PROXY_URL=https://generativelanguage.googleapis.com/v1beta/openapi
# MODEL_PROXY_API_KEY=...
# MODEL_PROXY_GENAI_SUPPORT=TRUE
# LLM_DEFAULT=gemini-2.0-flash
